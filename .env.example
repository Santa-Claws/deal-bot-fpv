# ─────────────────────────────────────────────────────
# FPV Deal Finder - Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
POSTGRES_USER=fpvdeals
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fpvdeals

# ── Meilisearch ───────────────────────────────────────
# Change this to a strong random string in production
MEILI_MASTER_KEY=changeme

# ── AI Configuration ──────────────────────────────────
# Ollama runs locally (see config/ai.yaml for model selection)
OLLAMA_HOST=http://ollama:11434

# Optional: OpenAI fallback if Ollama is unavailable
# Leave blank to disable OpenAI fallback
OPENAI_API_KEY=

# ── Discord Notifications ─────────────────────────────
# Create a webhook in Discord: Server Settings > Integrations > Webhooks
# Leave blank to disable notifications
DISCORD_WEBHOOK_URL=

# ── Scraping Settings ─────────────────────────────────
# How often to re-scrape each store (in hours)
SCRAPE_INTERVAL_HOURS=6

# Browser user agent for scraping (mimics real browser)
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# ── Logging ───────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
